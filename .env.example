# Turso Database（ダッシュボード・ワーカー共通）
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# NextAuth（GitHub OAuth用）
NEXTAUTH_SECRET=openssl rand -base64 32 で生成
NEXTAUTH_URL=http://localhost:3000
GITHUB_ID=GitHub OAuth AppのClient ID
GITHUB_SECRET=GitHub OAuth AppのClient Secret

# APIキー暗号化用（32文字以上、openssl rand -base64 32 で生成）
ENCRYPTION_KEY=

# 取引テスト用（本番移行前に true でペーパートレード、実際の注文なし）
# PAPER_TRADING=true

# ワーカー専用（Discord シグナル連動・自動売買を使う場合）
# DISCORD_BOT_TOKEN=Discord Bot トークン
# 監視対象チャンネル（最大10件、カンマ区切り）。単一の場合は DISCORD_CHANNEL_ID も可
# DISCORD_CHANNEL_IDS=123456789,987654321,111222333
# DISCORD_CHANNEL_ID=単一チャンネルの場合
# ANTHROPIC_API_KEY=Claude API キー
